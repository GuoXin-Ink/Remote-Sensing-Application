{
  "name": "Fox Glacier Feature Tracking Lab",
  "image": "mcr.microsoft.com/devcontainers/miniconda:3",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit viewer",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/rsa-lab/bin/python",
        "jupyter.notebookFileRoot": "${fileDirname}"
      }
    }
  }
}
