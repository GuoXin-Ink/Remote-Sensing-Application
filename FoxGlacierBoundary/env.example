# Copy to ".env" in this folder (same directory as the script) if you use python-dotenv.
# Do not commit ".env" — it may contain secrets.

# --- Microsoft Planetary Computer (optional) ---
# Anonymous STAC search works; a subscription key raises rate limits and avoids throttling.
# Create (free) at: https://planetarycomputer.microsoft.com/account/request
PC_SDK_SUBSCRIPTION_KEY=

# --- Copernicus Data Space (optional; only if you extend the script to use CDSE APIs) ---
# Use OAuth *client* credentials from the CDSE dashboard, not your web login password.
# CDSE_CLIENT_ID=
# CDSE_CLIENT_SECRET=
